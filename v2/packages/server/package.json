{
    "name": "@ocpp-sim/server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "scripts": {
        "dev": "tsx watch --exclude data --exclude '*.sqlite*' src/index.ts",
        "start": "tsx src/index.ts",
        "build": "tsc -p tsconfig.json",
        "test": "vitest run",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@fastify/cors": "^10.0.1",
        "@fastify/websocket": "^11.0.1",
        "@ocpp-sim/core": "*",
        "better-sqlite3": "^11.5.0",
        "fastify": "^5.1.0",
        "uuid": "^11.0.3",
        "ws": "^8.18.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.12",
        "@types/node": "^22.9.0",
        "@types/uuid": "^10.0.0",
        "@types/ws": "^8.5.13",
        "tsx": "^4.19.2",
        "typescript": "^5.6.3",
        "vitest": "^2.1.8"
    }
}
