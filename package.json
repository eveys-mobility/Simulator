{
    "name": "ocpp-sim",
    "version": "0.1.0",
    "private": true,
    "description": "OCPP 1.6J charge-point simulator — multi-device, device-first UX",
    "type": "module",
    "engines": {
        "node": ">=20"
    },
    "workspaces": ["packages/*"],
    "scripts": {
        "dev:server": "npm --workspace @ocpp-sim/server run dev",
        "dev:web": "npm --workspace @ocpp-sim/web run dev",
        "build": "npm --workspaces run build --if-present",
        "test": "npm --workspaces run test --if-present",
        "conformance": "npm --workspace @ocpp-sim/conformance run test",
        "lint": "biome check .",
        "format": "biome format --write ."
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "typescript": "^5.6.3"
    }
}
